{
  "version": "0.0.1-experimental.593681493255d3a39231f63454a967a71fdd7d66",
  "keywords": [
    "better-auth",
    "strapi",
    "database-adapter",
    "authentication"
  ],
  "type": "commonjs",
  "exports": {
    ".": {
      "source": "./server/src/adapter/index.ts",
      "types": "./dist/adapter/index.d.ts",
      "require": "./dist/adapter/index.js",
      "default": "./dist/adapter/index.js"
    },
    "./package.json": "./package.json",
    "./strapi-server": {
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "dev": "strapi-plugin watch",
    "verify": "strapi-plugin verify",
    "test:ts:back": "cd server && tsc --noEmit",
    "test:integration": "node --js-explicit-resource-management node_modules/vitest/vitest.mjs run",
    "check-types": "pnpm run test:ts:back",
    "lint": "biome check --fix"
  },
  "dependencies": {
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@better-auth/test-utils": "catalog:better-auth",
    "@biomejs/biome": "^2.3.11",
    "@strapi/sdk-plugin": "^6.0.0",
    "@strapi/typescript-utils": "catalog:strapi",
    "@types/koa": "^3.0.1",
    "@types/lodash": "^4.17.21",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@strapi-community/plugin-api-permissions": "workspace:*",
    "@strapi/strapi": "catalog:strapi",
    "@strapi/types": "catalog:strapi",
    "@strapi/utils": "catalog:strapi",
    "better-auth": ">=1.4.0 <2"
  },
  "peerDependenciesMeta": {
    "@strapi-community/plugin-api-permissions": {
      "optional": true
    }
  },
  "strapi": {
    "kind": "plugin",
    "name": "better-auth",
    "displayName": "Strapi Better Auth",
    "description": "Better Auth database adapter for Strapi"
  },
  "name": "@strapi-community/plugin-better-auth",
  "description": "Better Auth database adapter for Strapi",
  "license": "MIT",
  "author": {
    "name": "Boaz Poolman",
    "email": "boaz@pluginpal.io",
    "url": "https://github.com/boazpoolman"
  },
  "maintainers": [
    {
      "name": "Boaz Poolman",
      "email": "boaz@pluginpal.io",
      "url": "https://github.com/boazpoolman"
    }
  ],
  "bugs": {
    "url": "https://github.com/strapi-community/auth/issues"
  },
  "homepage": "https://github.com/strapi-community/auth",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strapi-community/auth.git",
    "directory": "packages/plugin-better-auth"
  }
}
