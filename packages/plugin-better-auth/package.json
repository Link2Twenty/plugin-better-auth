{
  "version": "0.0.1-experimental.f768670d38e0477718b8b96efd79a9d87687cc6c",
  "keywords": [
    "better-auth",
    "strapi",
    "database-adapter",
    "authentication"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-server": {
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./adapter": {
      "source": "./server/src/adapter/index.ts",
      "types": "./dist/adapter/index.d.ts",
      "require": "./dist/adapter/index.js",
      "default": "./dist/adapter/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "dev": "strapi-plugin watch",
    "verify": "strapi-plugin verify",
    "test:ts:back": "cd server && tsc --noEmit",
    "test": "node --js-explicit-resource-management node_modules/vitest/vitest.mjs run",
    "check-types": "pnpm run test:ts:back",
    "lint": "biome check --fix"
  },
  "dependencies": {
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@better-auth/test-utils": "catalog:better-auth",
    "@biomejs/biome": "^2.3.11",
    "@strapi/sdk-plugin": "^6.0.0",
    "@strapi/typescript-utils": "catalog:strapi",
    "@types/koa": "^3.0.1",
    "@types/lodash": "^4.17.21",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@strapi/strapi": "catalog:strapi",
    "@strapi/utils": "catalog:strapi",
    "better-auth": "catalog:better-auth"
  },
  "strapi": {
    "kind": "plugin",
    "name": "better-auth",
    "displayName": "Strapi Better Auth",
    "description": "Better Auth database adapter for Strapi"
  },
  "name": "@strapi-community/plugin-better-auth",
  "description": "Better Auth database adapter for Strapi",
  "license": "MIT",
  "author": {
    "name": "Boaz Poolman",
    "email": "boaz@pluginpal.io",
    "url": "https://github.com/boazpoolman"
  },
  "maintainers": [
    {
      "name": "Boaz Poolman",
      "email": "boaz@pluginpal.io",
      "url": "https://github.com/boazpoolman"
    }
  ],
  "bugs": {
    "url": "https://github.com/strapi-community/plugin-better-auth/issues"
  },
  "homepage": "https://github.com/strapi-community/plugin-better-auth",
  "repository": {
    "type": "git",
    "url": "git://github.com/strapi-community/plugin-better-auth.git"
  }
}
