{
  "name": "@strapi-community/plugin-api-permissions",
  "version": "1.0.0-alpha.1",
  "description": "Content API RBAC for Strapi — auth-provider agnostic roles and permissions",
  "keywords": [
    "strapi",
    "plugin",
    "rbac",
    "permissions",
    "roles"
  ],
  "license": "MIT",
  "author": {
    "name": "Boaz Poolman",
    "email": "boaz@pluginpal.io",
    "url": "https://github.com/boazpoolman"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/strapi-community/plugin-better-auth.git"
  },
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "dev": "strapi-plugin watch",
    "test:ts:back": "cd server && tsc --noEmit",
    "check-types": "pnpm run test:ts:back",
    "lint": "biome check --fix",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@playwright/test": "^1.49.0",
    "@strapi/sdk-plugin": "^6.0.0",
    "@strapi/strapi": "catalog:strapi",
    "@strapi/typescript-utils": "catalog:strapi",
    "@types/koa": "^3.0.1",
    "@types/lodash": "^4.17.21",
    "@types/node": "^22",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@strapi/strapi": "^5.0.0",
    "@strapi/utils": "^5.0.0",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-intl": "^6.0.0 || ^7.0.0",
    "styled-components": "^5.0.0 || ^6.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "api-permissions",
    "displayName": "API Permissions",
    "description": "Content API RBAC for Strapi"
  }
}
