{
  "kind": "collectionType",
  "collectionName": "ba_user",
  "info": {
    "singularName": "user",
    "pluralName": "users",
    "displayName": "Users"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    },
    "content-type-builder": {
      "visible": true
    }
  },
  "attributes": {
    "name": {
      "type": "text",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true
    },
    "emailVerified": {
      "type": "boolean",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true,
      "default": false
    },
    "image": {
      "type": "text",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      }
    },
    "roles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::api-permissions.role",
      "writable": true,
      "configurable": false,
      "editable": false,
      "visible": true,
      "default": null
    },
    "email": {
      "type": "email",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true,
      "unique": true
    },
    "verified": {
      "type": "boolean"
    },
    "twoFactorEnabled": {
      "type": "boolean",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "default": false
    }
  }
}
