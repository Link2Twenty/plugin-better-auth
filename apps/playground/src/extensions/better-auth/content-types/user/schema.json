{
  "kind": "collectionType",
  "collectionName": "ba_user",
  "info": {
    "singularName": "user",
    "pluralName": "users",
    "displayName": "Users"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": false
    },
    "content-type-builder": {
      "visible": true
    }
  },
  "attributes": {
    "name": {
      "type": "text",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true
    },
    "emailVerified": {
      "type": "boolean",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true,
      "default": false
    },
    "image": {
      "type": "text",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      }
    },
    "roles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::api-permissions.role",
      "writable": true,
      "configurable": false,
      "editable": false,
      "visible": true,
      "default": null
    },
    "email": {
      "type": "email",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true,
      "unique": true
    },
    "twoFactorEnabled": {
      "type": "boolean",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "default": false
    },
    "verified": {
      "type": "boolean"
    },
    "test": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::test.test"
    },
    "role": {
      "type": "text",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      }
    },
    "banned": {
      "type": "boolean",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "default": false
    },
    "banReason": {
      "type": "text",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      }
    },
    "banExpires": {
      "type": "datetime",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      }
    }
  }
}
