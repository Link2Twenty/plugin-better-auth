{
  "version": "1.0.0-alpha.1",
  "keywords": [
    "better-auth",
    "strapi",
    "database-adapter",
    "authentication"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "run -T tsc -p admin/tsconfig.json",
    "test:ts:back": "run -T tsc -p server/tsconfig.json",
    "lint": "biome check --fix ."
  },
  "dependencies": {
    "better-auth": "^1.4.10",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@strapi/sdk-plugin": "^5.4.0",
    "@strapi/strapi": "^5.33.2",
    "@strapi/typescript-utils": "^5.33.2",
    "@types/koa": "^3.0.1",
    "@types/lodash": "^4.17.21",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@strapi/sdk-plugin": "^5.0.0",
    "@strapi/strapi": "^5.0.0",
    "@strapi/utils": "^5.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "better-auth",
    "displayName": "Strapi Better Auth",
    "description": "Better Auth database adapter for Strapi"
  },
  "name": "@strapi-community/plugin-better-auth",
  "description": "Better Auth database adapter for Strapi",
  "license": "MIT",
  "author": "Boaz Poolman <boaz@pluginpal.io>"
}
